{% extends 'base.html.twig' %}

{% block title %}Login — Admin{% endblock %}

{% block body %}

    <section class="min-h-screen hero-gradient relative flex items-center justify-center py-24 overflow-hidden">
        <div class="absolute inset-0 hero-pattern"></div>
        <div class="relative z-10 w-full max-w-[24rem] mx-auto px-5">
            <div class="bg-white rounded-2xl border border-cream-dark/50 p-8 sm:p-10">
                <div class="text-center mb-8">
                    <div class="w-12 h-12 rounded-xl bg-navy flex items-center justify-center mx-auto mb-5">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>
                        </svg>
                    </div>
                    <h1 class="font-display text-[1.5rem] font-bold text-navy">Admin Login</h1>
                </div>

                {% if error %}
                    <div class="mb-6 p-4 rounded-xl bg-red-50 border border-red-200 text-red-800 text-[0.8125rem]">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <form method="post" class="space-y-5">
                    <div>
                        <label for="username" class="form-label">Username</label>
                        <input type="text" id="username" name="_username" value="{{ last_username }}" required autofocus class="form-input">
                    </div>

                    <div>
                        <label for="password" class="form-label">Password</label>
                        <input type="password" id="password" name="_password" required class="form-input">
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <button type="submit" class="btn-primary w-full justify-center">
                        Login
                    </button>
                </form>
            </div>
        </div>
    </section>

{% endblock %}
