{% extends 'base.html.twig' %}

{% block title %}{{ 'home.hero.name'|trans }} — {{ 'home.hero.subtitle'|trans }}{% endblock %}

{% block body %}

    {# === HERO === #}
    <section class="relative min-h-screen hero-gradient flex items-center overflow-hidden">
        {# Background pattern #}
        <div class="absolute inset-0 hero-pattern"></div>

        <div class="relative z-10 max-w-6xl mx-auto px-5 sm:px-8 lg:px-10 w-full grid grid-cols-1 lg:grid-cols-2 gap-16 items-center py-28 lg:py-0">

            {# Left: Content #}
            <div>
                {# DP Badge #}
                <div class="fade-up inline-flex items-center gap-2.5 px-4 py-2 rounded-full border border-white/8 bg-white/[0.04] mb-10">
                    <span class="w-2 h-2 rounded-full bg-gold"></span>
                    <span class="text-[0.65rem] font-bold uppercase tracking-[0.18em] text-white/60">{{ 'home.hero.badge'|trans }}</span>
                </div>

                {# Name #}
                <h1 class="font-display font-bold tracking-tight mb-8">
                    <span class="fade-up-delay-1 block text-[3.2rem] sm:text-[4rem] lg:text-[5.25rem] text-white leading-[0.95]">{{ 'home.hero.firstname'|trans }}</span>
                    <span class="fade-up-delay-2 block text-[3.2rem] sm:text-[4rem] lg:text-[5.25rem] text-white leading-[0.95] mt-1">{{ 'home.hero.lastname'|trans }}</span>
                </h1>

                {# Gold rule #}
                <div class="fade-up-delay-3 w-16 h-[2px] bg-gradient-to-r from-gold to-transparent mb-8"></div>

                {# Tagline #}
                <p class="fade-up-delay-3 text-[1.15rem] sm:text-[1.35rem] text-white/60 font-light leading-relaxed mb-12 max-w-md">
                    {{ 'home.hero.tagline'|trans|raw }}
                </p>

                {# CTAs #}
                <div class="fade-up-delay-4 flex flex-wrap gap-4">
                    <a href="#themes" class="btn-white">
                        {{ 'home.hero.cta_primary'|trans }}
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </a>
                    <a href="#contact" class="btn-ghost">
                        {{ 'home.hero.cta_secondary'|trans }}
                    </a>
                </div>
            </div>

            {# Right: Photo #}
            <div class="fade-up-delay-3 hidden lg:flex items-center justify-center">
                <div class="photo-frame w-[21rem] h-[21rem] rounded-full overflow-hidden">
                    <img src="{{ asset('images/mika.jpg') }}" alt="Mika Ferreira" class="w-full h-full object-cover rounded-full">
                </div>
            </div>
        </div>

        {# Scroll indicator #}
        <div class="fade-up-delay-5 absolute bottom-10 left-8 flex items-center gap-4">
            <div class="w-px h-14 bg-white/15"></div>
            <div class="flex flex-col gap-1">
                <span class="text-[0.6rem] uppercase tracking-[0.2em] text-white/30 font-semibold">{{ 'home.hero.scroll'|trans }}</span>
                <svg class="w-3.5 h-3.5 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="animation: scrollPulse 2s ease-in-out infinite">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7"/>
                </svg>
            </div>
        </div>
    </section>

    {# === ABOUT === #}
    <section id="about" class="py-28 bg-cream">
        <div class="max-w-6xl mx-auto px-5 sm:px-8 lg:px-10">
            <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.3fr] gap-20">

                {# Left: Sticky headline #}
                <div class="lg:sticky lg:top-32 lg:self-start">
                    <p class="section-label mb-6">{{ 'home.about.label'|trans }}</p>
                    <h2 class="font-display text-[1.85rem] sm:text-[2.35rem] font-bold text-navy leading-[1.2]">
                        {{ 'home.about.headline'|trans|raw }}
                    </h2>
                </div>

                {# Right: Story #}
                <div>
                    <p class="text-text-muted leading-[1.8] mb-7 text-[0.95rem]">
                        {{ 'home.about.p1'|trans }}
                    </p>
                    <p class="text-text-muted leading-[1.8] mb-7 text-[0.95rem]">
                        {{ 'home.about.p2'|trans }}
                    </p>
                    <p class="text-text-muted leading-[1.8] mb-12 text-[0.95rem]">
                        {{ 'home.about.p3'|trans }}
                    </p>

                    {# Inclusion Card #}
                    <div class="inclusion-card mb-12">
                        <h3 class="font-display font-bold text-navy mb-2 text-[1.05rem]">{{ 'home.about.card_title'|trans }}</h3>
                        <p class="text-text-muted text-[0.875rem] leading-relaxed">{{ 'home.about.card_text'|trans }}</p>
                    </div>

                    {# Values #}
                    <h3 class="font-display text-[1.15rem] font-bold text-navy mb-4">{{ 'home.about.promises_title'|trans }}</h3>
                    <div>
                        <div class="value-item">
                            <span class="value-number">01</span>
                            <p class="text-text-muted text-[0.875rem] leading-relaxed">{{ 'home.about.value_01'|trans }}</p>
                        </div>
                        <div class="value-item">
                            <span class="value-number">02</span>
                            <p class="text-text-muted text-[0.875rem] leading-relaxed">{{ 'home.about.value_02'|trans }}</p>
                        </div>
                        <div class="value-item">
                            <span class="value-number">03</span>
                            <p class="text-text-muted text-[0.875rem] leading-relaxed">{{ 'home.about.value_03'|trans }}</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# === THEMES === #}
    <section id="themes" class="py-28 bg-navy">
        <div class="max-w-6xl mx-auto px-5 sm:px-8 lg:px-10">
            <div class="text-center mb-14">
                <p class="text-[0.6rem] font-bold uppercase tracking-[0.2em] text-white/30 mb-4">{{ 'home.about.label'|trans }}</p>
                <h2 class="font-display text-[1.85rem] sm:text-[2.35rem] font-bold text-white">
                    {{ 'home.themes.title'|trans }}
                </h2>
            </div>

            <div class="theme-grid">
                {# Inclusion #}
                <div class="theme-card">
                    <span class="theme-number absolute top-5 right-7 font-display text-[3.5rem] font-bold text-white/[0.04] leading-none">01</span>
                    <div class="w-11 h-11 rounded-lg bg-blue/15 flex items-center justify-center mb-6">
                        <svg class="w-5 h-5 text-blue-vivid" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
                        </svg>
                    </div>
                    <h3 class="font-display text-[1.1rem] font-semibold text-white mb-3">
                        {{ 'home.themes.inclusion.title'|trans }}
                    </h3>
                    <p class="text-white/50 text-[0.825rem] leading-[1.7]">
                        {{ 'home.themes.inclusion.text_long'|trans }}
                    </p>
                </div>

                {# Youth #}
                <div class="theme-card">
                    <span class="theme-number absolute top-5 right-7 font-display text-[3.5rem] font-bold text-white/[0.04] leading-none">02</span>
                    <div class="w-11 h-11 rounded-lg bg-blue/15 flex items-center justify-center mb-6">
                        <svg class="w-5 h-5 text-blue-vivid" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>
                        </svg>
                    </div>
                    <h3 class="font-display text-[1.1rem] font-semibold text-white mb-3">
                        {{ 'home.themes.youth.title'|trans }}
                    </h3>
                    <p class="text-white/50 text-[0.825rem] leading-[1.7]">
                        {{ 'home.themes.youth.text_long'|trans }}
                    </p>
                </div>

                {# Housing #}
                <div class="theme-card">
                    <span class="theme-number absolute top-5 right-7 font-display text-[3.5rem] font-bold text-white/[0.04] leading-none">03</span>
                    <div class="w-11 h-11 rounded-lg bg-blue/15 flex items-center justify-center mb-6">
                        <svg class="w-5 h-5 text-blue-vivid" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>
                        </svg>
                    </div>
                    <h3 class="font-display text-[1.1rem] font-semibold text-white mb-3">
                        {{ 'home.themes.housing.title'|trans }}
                    </h3>
                    <p class="text-white/50 text-[0.825rem] leading-[1.7]">
                        {{ 'home.themes.housing.text_long'|trans }}
                    </p>
                </div>

                {# Culture #}
                <div class="theme-card">
                    <span class="theme-number absolute top-5 right-7 font-display text-[3.5rem] font-bold text-white/[0.04] leading-none">04</span>
                    <div class="w-11 h-11 rounded-lg bg-blue/15 flex items-center justify-center mb-6">
                        <svg class="w-5 h-5 text-blue-vivid" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 9l10.5-3m0 6.553v3.75a2.25 2.25 0 01-1.632 2.163l-1.32.377a1.803 1.803 0 11-.99-3.467l2.31-.66a2.25 2.25 0 001.632-2.163zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 01-1.632 2.163l-1.32.377a1.803 1.803 0 01-.99-3.467l2.31-.66A2.25 2.25 0 009 15.553z"/>
                        </svg>
                    </div>
                    <h3 class="font-display text-[1.1rem] font-semibold text-white mb-3">
                        {{ 'home.themes.culture.title'|trans }}
                    </h3>
                    <p class="text-white/50 text-[0.825rem] leading-[1.7]">
                        {{ 'home.themes.culture.text_long'|trans }}
                    </p>
                </div>
            </div>
        </div>
    </section>

    {# === NEWS PREVIEW === #}
    <section id="news" class="py-28 bg-white">
        <div class="max-w-6xl mx-auto px-5 sm:px-8 lg:px-10">
            <div class="flex items-end justify-between mb-14">
                <div>
                    <p class="section-label mb-4">{{ 'home.news.title'|trans }}</p>
                    <h2 class="font-display text-[1.85rem] sm:text-[2.35rem] font-bold text-navy">
                        {{ 'home.news.title'|trans }}
                    </h2>
                </div>
                {% set news_route = app.request.locale == 'en' ? 'app_news_en' : 'app_news' %}
                <a href="{{ path(news_route) }}" class="group hidden sm:inline-flex items-center gap-2 text-[0.8rem] font-semibold text-blue hover:text-navy transition-colors">
                    {{ 'home.news.all'|trans }}
                    <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                </a>
            </div>

            {% if latestNews is not empty %}
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-7">
                    {% for article in latestNews %}
                        {% set show_route = app.request.locale == 'en' ? 'app_news_show_en' : 'app_news_show' %}
                        <a href="{{ path(show_route, {slug: article.slug}) }}" class="news-card group block p-7 rounded-2xl bg-cream border border-cream-dark/50">
                            <div class="flex items-center gap-3 mb-4">
                                <time class="text-[0.7rem] text-text-soft tracking-wide" datetime="{{ article.publishedAt|date('Y-m-d') }}">
                                    {{ article.publishedAt|date('d.m.Y') }}
                                </time>
                                <span class="px-2.5 py-0.5 text-[0.65rem] font-bold uppercase tracking-wider rounded-full bg-blue-light text-blue">
                                    {{ ('home.themes.' ~ article.category ~ '.title')|trans }}
                                </span>
                            </div>
                            <h3 class="font-display text-[1.05rem] font-semibold text-navy leading-snug group-hover:text-blue transition-colors duration-300">
                                {{ article.getTitle(app.request.locale) }}
                            </h3>
                        </a>
                    {% endfor %}
                </div>

                {# Mobile "all news" link #}
                <div class="mt-8 sm:hidden text-center">
                    <a href="{{ path(news_route) }}" class="inline-flex items-center gap-2 text-sm font-semibold text-blue">
                        {{ 'home.news.all'|trans }}
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                    </a>
                </div>
            {% endif %}
        </div>
    </section>

    {# === CONTACT === #}
    <section id="contact" class="py-28 bg-cream">
        <div class="max-w-6xl mx-auto px-5 sm:px-8 lg:px-10">
            <div class="text-center max-w-2xl mx-auto mb-16">
                <p class="section-label justify-center mb-6">{{ 'home.contact.label'|trans }}</p>
                <h2 class="font-display text-[1.85rem] sm:text-[2.35rem] font-bold text-navy mb-6 leading-tight">
                    {{ 'home.contact.headline'|trans }}
                </h2>
                <p class="text-text-muted leading-[1.8] text-[0.95rem]">
                    {{ 'home.contact.description'|trans }}
                </p>
            </div>

            {# Contact Cards Grid #}
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 max-w-3xl mx-auto mb-14">
                {# Email Card #}
                <a href="mailto:email@michael-ferreira.com" class="contact-card group flex items-center gap-5 p-6 rounded-2xl bg-white border border-cream-dark/50">
                    <div class="w-12 h-12 rounded-xl bg-blue-light flex items-center justify-center group-hover:bg-blue group-hover:scale-105 transition-all duration-300">
                        <svg class="w-5 h-5 text-blue group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
                        </svg>
                    </div>
                    <div>
                        <span class="block text-[0.65rem] font-bold uppercase tracking-[0.15em] text-text-soft mb-1">E-Mail</span>
                        <span class="text-navy text-[0.875rem] font-medium group-hover:text-blue transition-colors">email@michael-ferreira.com</span>
                    </div>
                </a>
                {# Location Card #}
                <div class="contact-card group flex items-center gap-5 p-6 rounded-2xl bg-white border border-cream-dark/50">
                    <div class="w-12 h-12 rounded-xl bg-blue-light flex items-center justify-center">
                        <svg class="w-5 h-5 text-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
                        </svg>
                    </div>
                    <div>
                        <span class="block text-[0.65rem] font-bold uppercase tracking-[0.15em] text-text-soft mb-1">{{ 'home.contact.location'|trans }}</span>
                        <span class="text-navy text-[0.875rem] font-medium">Luxembourg</span>
                    </div>
                </div>
            </div>

            {# Social Links Row #}
            <div class="flex items-center justify-center gap-4">
                <a href="https://www.facebook.com/unique.mf.95/" target="_blank" rel="noopener noreferrer" class="social-icon group w-12 h-12 rounded-full bg-white border border-cream-dark/50 flex items-center justify-center" aria-label="Facebook">
                    <svg class="w-5 h-5 text-text-muted group-hover:text-[#1877F2] transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                    </svg>
                </a>
                <a href="https://www.instagram.com/michaelferreira.lu/" target="_blank" rel="noopener noreferrer" class="social-icon group w-12 h-12 rounded-full bg-white border border-cream-dark/50 flex items-center justify-center" aria-label="Instagram">
                    <svg class="w-5 h-5 text-text-muted group-hover:text-[#E4405F] transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                    </svg>
                </a>
                <a href="https://www.linkedin.com/in/michael-ferreira-2b53449a/" target="_blank" rel="noopener noreferrer" class="social-icon group w-12 h-12 rounded-full bg-white border border-cream-dark/50 flex items-center justify-center" aria-label="LinkedIn">
                    <svg class="w-5 h-5 text-text-muted group-hover:text-[#0A66C2] transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                    </svg>
                </a>
            </div>
        </div>
    </section>

{% endblock %}
