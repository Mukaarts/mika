{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard{% endblock %}

{% block body %}

    {# === Hero banner === #}
    <section class="relative pt-36 pb-20 hero-gradient overflow-hidden">
        <div class="absolute inset-0 hero-pattern"></div>
        <div class="relative z-10 max-w-5xl mx-auto px-5 sm:px-8 lg:px-10">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-[0.6rem] font-bold uppercase tracking-[0.18em] text-white/40 mb-3">Admin</p>
                    <h1 class="font-display text-[2rem] sm:text-[2.5rem] font-bold text-white">Dashboard</h1>
                </div>
                <div class="flex items-center gap-5">
                    <a href="{{ path('app_admin_news_create') }}" class="btn-white text-[0.8rem]">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                        </svg>
                        Neien Artikel
                    </a>
                    <a href="{{ path('app_logout') }}" class="text-[0.8rem] text-white/50 hover:text-white transition-colors font-medium">Logout</a>
                </div>
            </div>
        </div>
    </section>

    {# === Content === #}
    <section class="py-20 bg-cream">
        <div class="max-w-5xl mx-auto px-5 sm:px-8 lg:px-10">

            {# Flash Messages #}
            {% for message in app.flashes('success') %}
                <div class="mb-8 p-5 rounded-xl bg-green-50 border border-green-200 text-green-800 text-[0.875rem] -mt-12 relative z-20">
                    {{ message }}
                </div>
            {% endfor %}

            {# Articles Table #}
            {% if articles is empty %}
                <div class="text-center -mt-12 relative z-20">
                    <div class="contact-card inline-block p-12 rounded-2xl bg-white border border-cream-dark/50">
                        <svg class="w-10 h-10 text-text-soft mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z"/>
                        </svg>
                        <p class="text-text-muted text-[0.95rem] mb-4">Keng Artikelen am Moment.</p>
                        <a href="{{ path('app_admin_news_create') }}" class="text-blue hover:text-navy font-semibold text-[0.875rem]">Éischten Artikel schreiwen</a>
                    </div>
                </div>
            {% else %}
                <div class="bg-white border border-cream-dark/50 rounded-2xl overflow-hidden -mt-12 relative z-20">
                    <table class="admin-table w-full text-[0.8125rem]">
                        <thead>
                            <tr class="border-b border-cream-dark bg-cream/60">
                                <th class="text-left px-6 py-4 font-semibold text-navy text-[0.65rem] uppercase tracking-[0.15em]">Titel</th>
                                <th class="text-left px-6 py-4 font-semibold text-navy text-[0.65rem] uppercase tracking-[0.15em] hidden sm:table-cell">Kategorie</th>
                                <th class="text-left px-6 py-4 font-semibold text-navy text-[0.65rem] uppercase tracking-[0.15em] hidden md:table-cell">Datum</th>
                                <th class="text-right px-6 py-4 font-semibold text-navy text-[0.65rem] uppercase tracking-[0.15em]">Aktiounen</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for article in articles %}
                                <tr class="border-b border-cream-dark/50 last:border-0">
                                    <td class="px-6 py-5">
                                        <div class="font-medium text-navy">{{ article.titleLb }}</div>
                                        <div class="text-[0.7rem] text-text-soft mt-1">{{ article.titleEn }}</div>
                                    </td>
                                    <td class="px-6 py-5 hidden sm:table-cell">
                                        <span class="px-2.5 py-0.5 text-[0.65rem] font-bold uppercase tracking-wider rounded-full bg-blue-light text-blue">
                                            {{ article.category }}
                                        </span>
                                    </td>
                                    <td class="px-6 py-5 text-text-muted hidden md:table-cell">
                                        {{ article.publishedAt|date('d.m.Y') }}
                                    </td>
                                    <td class="px-6 py-5 text-right">
                                        <div class="flex items-center justify-end gap-4">
                                            <a href="{{ path('app_admin_news_edit', {id: article.id}) }}" class="text-blue hover:text-navy transition-colors" title="Änneren">
                                                <svg class="w-[1.1rem] h-[1.1rem]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                                </svg>
                                            </a>
                                            <form method="post" action="{{ path('app_admin_news_delete', {id: article.id}) }}" onsubmit="return confirm('Dësen Artikel wierklech läschen?')">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete-' ~ article.id) }}">
                                                <button type="submit" class="text-red-400 hover:text-red-600 transition-colors" title="Läschen">
                                                    <svg class="w-[1.1rem] h-[1.1rem]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                                    </svg>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </section>

{% endblock %}
