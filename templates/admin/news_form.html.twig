{% extends 'base.html.twig' %}

{% block title %}{{ editing ? 'Artikel änneren' : 'Neien Artikel' }} — Admin{% endblock %}

{% block body %}

    {# === Hero banner === #}
    <section class="relative pt-36 pb-20 hero-gradient overflow-hidden">
        <div class="absolute inset-0 hero-pattern"></div>
        <div class="relative z-10 max-w-3xl mx-auto px-5 sm:px-8 lg:px-10">
            <div class="flex items-center gap-5">
                <a href="{{ path('app_admin') }}" class="group w-10 h-10 rounded-xl bg-white/8 hover:bg-white/15 flex items-center justify-center transition-colors" aria-label="Zréck">
                    <svg class="w-4 h-4 text-white/60 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                    </svg>
                </a>
                <h1 class="font-display text-[1.85rem] sm:text-[2.25rem] font-bold text-white">
                    {{ editing ? 'Artikel änneren' : 'Neien Artikel' }}
                </h1>
            </div>
        </div>
    </section>

    {# === Form === #}
    <section class="py-20 bg-cream">
        <div class="max-w-3xl mx-auto px-5 sm:px-8 lg:px-10">
            <div class="bg-white rounded-2xl border border-cream-dark/50 p-7 sm:p-10 -mt-12 relative z-20">
                {{ form_start(form, {attr: {class: 'space-y-7'}}) }}

                    {# Language Tabs #}
                    <div>
                        <div class="admin-tabs" role="tablist">
                            <button type="button" class="admin-tab active" role="tab" aria-selected="true" data-tab="lb" onclick="switchTab('lb')">
                                Lëtzebuergesch
                            </button>
                            <button type="button" class="admin-tab" role="tab" aria-selected="false" data-tab="en" onclick="switchTab('en')">
                                English
                            </button>
                        </div>

                        {# Tab: Lëtzebuergesch #}
                        <div class="admin-tab-panel" data-tab-panel="lb">
                            <div class="space-y-5">
                                <div>
                                    {{ form_label(form.titleLb, null, {label_attr: {class: 'form-label'}}) }}
                                    {{ form_widget(form.titleLb, {attr: {class: 'form-input'}}) }}
                                    {{ form_errors(form.titleLb, {attr: {class: 'mt-1 text-sm text-red-600'}}) }}
                                </div>
                                <div>
                                    {{ form_label(form.summaryLb, null, {label_attr: {class: 'form-label'}}) }}
                                    {{ form_widget(form.summaryLb, {attr: {class: 'form-input resize-y min-h-[100px]'}}) }}
                                    {{ form_errors(form.summaryLb, {attr: {class: 'mt-1 text-sm text-red-600'}}) }}
                                </div>
                                <div>
                                    {{ form_label(form.contentLb, null, {label_attr: {class: 'form-label'}}) }}
                                    {{ form_widget(form.contentLb, {attr: {class: 'form-input resize-y min-h-[220px]'}}) }}
                                    {{ form_errors(form.contentLb, {attr: {class: 'mt-1 text-sm text-red-600'}}) }}
                                </div>
                            </div>
                        </div>

                        {# Tab: English #}
                        <div class="admin-tab-panel hidden" data-tab-panel="en">
                            <div class="space-y-5">
                                <div>
                                    {{ form_label(form.titleEn, null, {label_attr: {class: 'form-label'}}) }}
                                    {{ form_widget(form.titleEn, {attr: {class: 'form-input'}}) }}
                                    {{ form_errors(form.titleEn, {attr: {class: 'mt-1 text-sm text-red-600'}}) }}
                                </div>
                                <div>
                                    {{ form_label(form.summaryEn, null, {label_attr: {class: 'form-label'}}) }}
                                    {{ form_widget(form.summaryEn, {attr: {class: 'form-input resize-y min-h-[100px]'}}) }}
                                    {{ form_errors(form.summaryEn, {attr: {class: 'mt-1 text-sm text-red-600'}}) }}
                                </div>
                                <div>
                                    {{ form_label(form.contentEn, null, {label_attr: {class: 'form-label'}}) }}
                                    {{ form_widget(form.contentEn, {attr: {class: 'form-input resize-y min-h-[220px]'}}) }}
                                    {{ form_errors(form.contentEn, {attr: {class: 'mt-1 text-sm text-red-600'}}) }}
                                </div>
                            </div>
                        </div>
                    </div>

                    {# Section: Meta #}
                    <div>
                        <p class="text-[0.65rem] font-bold uppercase tracking-[0.15em] text-text-soft mb-4">Meta</p>
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
                            <div>
                                {{ form_label(form.category, null, {label_attr: {class: 'form-label'}}) }}
                                {{ form_widget(form.category, {attr: {class: 'form-input'}}) }}
                                {{ form_errors(form.category, {attr: {class: 'mt-1 text-sm text-red-600'}}) }}
                            </div>
                            <div>
                                {{ form_label(form.slug, null, {label_attr: {class: 'form-label'}}) }}
                                {{ form_widget(form.slug, {attr: {class: 'form-input'}}) }}
                                {{ form_errors(form.slug, {attr: {class: 'mt-1 text-sm text-red-600'}}) }}
                            </div>
                            <div>
                                {{ form_label(form.publishedAt, null, {label_attr: {class: 'form-label'}}) }}
                                {{ form_widget(form.publishedAt, {attr: {class: 'form-input'}}) }}
                                {{ form_errors(form.publishedAt, {attr: {class: 'mt-1 text-sm text-red-600'}}) }}
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center gap-5 pt-2 border-t border-cream-dark/50">
                        <button type="submit" class="btn-primary mt-5">
                            {{ editing ? 'Späicheren' : 'Publizéieren' }}
                        </button>
                        <a href="{{ path('app_admin') }}" class="mt-5 text-[0.8125rem] text-text-muted hover:text-navy transition-colors font-medium">Ofbriechen</a>
                    </div>

                {{ form_end(form) }}
            </div>
        </div>
    </section>

    <script>
        function switchTab(lang) {
            document.querySelectorAll('.admin-tab').forEach(function(tab) {
                var isActive = tab.dataset.tab === lang;
                tab.classList.toggle('active', isActive);
                tab.setAttribute('aria-selected', isActive);
            });
            document.querySelectorAll('.admin-tab-panel').forEach(function(panel) {
                panel.classList.toggle('hidden', panel.dataset.tabPanel !== lang);
            });
        }

        // Auto-generate slug from English title
        (function() {
            var titleEn = document.getElementById('{{ form.titleEn.vars.id }}');
            var slug = document.getElementById('{{ form.slug.vars.id }}');
            if (!titleEn || !slug) return;

            var manualEdit = slug.value !== '';

            slug.addEventListener('input', function() {
                manualEdit = true;
            });

            titleEn.addEventListener('input', function() {
                if (manualEdit) return;
                slug.value = titleEn.value
                    .toLowerCase()
                    .trim()
                    .replace(/[àáâãäå]/g, 'a')
                    .replace(/[èéêë]/g, 'e')
                    .replace(/[ìíîï]/g, 'i')
                    .replace(/[òóôõö]/g, 'o')
                    .replace(/[ùúûü]/g, 'u')
                    .replace(/[ñ]/g, 'n')
                    .replace(/[ç]/g, 'c')
                    .replace(/[^a-z0-9\s-]/g, '')
                    .replace(/[\s]+/g, '-')
                    .replace(/-+/g, '-')
                    .replace(/^-|-$/g, '');
            });
        })();
    </script>

{% endblock %}
