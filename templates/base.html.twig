<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Mika Ferreira — DP Kayl-Téiteng{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🇱🇺</text></svg>">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Figtree:wght@300..900&display=swap" rel="stylesheet">
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="bg-cream text-text font-body antialiased min-h-screen flex flex-col">

        {# --- Header / Navigation --- #}
        <header class="fixed top-0 left-0 right-0 z-50 nav-glass border-b border-cream-dark/60"
                data-controller="nav">
            <div class="max-w-6xl mx-auto px-5 sm:px-8 lg:px-10">
                <div class="flex items-center justify-between h-[4.25rem]">

                    {# Logo #}
                    {% set home_route = app.request.locale == 'en' ? 'app_home_en' : 'app_home' %}
                    <a href="{{ path(home_route) }}" class="group font-display text-[1.3rem] font-bold tracking-tight text-navy transition-colors">
                        Mika <span class="text-blue group-hover:text-gold transition-colors duration-300">Ferreira</span>
                    </a>

                    {# Desktop Navigation #}
                    <nav class="hidden min-[900px]:flex items-center gap-10">
                        {% set news_route = app.request.locale == 'en' ? 'app_news_en' : 'app_news' %}
                        {% set contact_route = app.request.locale == 'en' ? 'app_contact_en' : 'app_contact' %}

                        <a href="{{ path(home_route) }}" class="nav-link text-[0.7rem] font-semibold uppercase tracking-[0.15em] text-text-muted hover:text-navy transition-colors">
                            {{ 'nav.home'|trans }}
                        </a>
                        <a href="{{ path(news_route) }}" class="nav-link text-[0.7rem] font-semibold uppercase tracking-[0.15em] text-text-muted hover:text-navy transition-colors">
                            {{ 'nav.news'|trans }}
                        </a>
                        <a href="{{ path(contact_route) }}" class="nav-link text-[0.7rem] font-semibold uppercase tracking-[0.15em] text-text-muted hover:text-navy transition-colors">
                            {{ 'nav.contact'|trans }}
                        </a>

                        {# Language Toggle Pill #}
                        {% set current_route = app.request.attributes.get('_route') %}
                        {% if app.request.locale == 'lb' %}
                            {% set route_map = {
                                'app_home': 'app_home_en',
                                'app_news': 'app_news_en',
                                'app_news_show': 'app_news_show_en',
                                'app_contact': 'app_contact_en'
                            } %}
                            {% set switch_route = route_map[current_route] ?? 'app_home_en' %}
                            {% set switch_params = app.request.attributes.get('_route_params', {}) %}
                            <div class="lang-toggle ml-2">
                                <a href="{{ path(home_route) }}" class="active">LU</a>
                                <a href="{{ path(switch_route, switch_params) }}">EN</a>
                            </div>
                        {% else %}
                            {% set route_map = {
                                'app_home_en': 'app_home',
                                'app_news_en': 'app_news',
                                'app_news_show_en': 'app_news_show',
                                'app_contact_en': 'app_contact'
                            } %}
                            {% set switch_route = route_map[current_route] ?? 'app_home' %}
                            {% set switch_params = app.request.attributes.get('_route_params', {}) %}
                            <div class="lang-toggle ml-2">
                                <a href="{{ path(switch_route, switch_params) }}">LU</a>
                                <a href="{{ path(home_route) }}" class="active">EN</a>
                            </div>
                        {% endif %}
                    </nav>

                    {# Mobile Hamburger #}
                    <button class="min-[900px]:hidden text-navy hover:text-blue transition-colors"
                            data-action="nav#toggle"
                            aria-label="Menu">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path data-nav-target="openIcon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                            <path data-nav-target="closeIcon" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </div>

                {# Mobile Menu #}
                <div class="hidden min-[900px]:hidden pb-5 pt-1" data-nav-target="menu">
                    {% set news_route = app.request.locale == 'en' ? 'app_news_en' : 'app_news' %}
                    {% set contact_route = app.request.locale == 'en' ? 'app_contact_en' : 'app_contact' %}

                    <a href="{{ path(home_route) }}" class="block py-2.5 text-sm font-semibold uppercase tracking-wider text-text-muted hover:text-navy transition-colors">
                        {{ 'nav.home'|trans }}
                    </a>
                    <a href="{{ path(news_route) }}" class="block py-2.5 text-sm font-semibold uppercase tracking-wider text-text-muted hover:text-navy transition-colors">
                        {{ 'nav.news'|trans }}
                    </a>
                    <a href="{{ path(contact_route) }}" class="block py-2.5 text-sm font-semibold uppercase tracking-wider text-text-muted hover:text-navy transition-colors">
                        {{ 'nav.contact'|trans }}
                    </a>

                    {# Mobile Language Toggle #}
                    {% if app.request.locale == 'lb' %}
                        {% set route_map = {
                            'app_home': 'app_home_en',
                            'app_news': 'app_news_en',
                            'app_news_show': 'app_news_show_en',
                            'app_contact': 'app_contact_en'
                        } %}
                        {% set switch_route = route_map[app.request.attributes.get('_route')] ?? 'app_home_en' %}
                        {% set switch_params = app.request.attributes.get('_route_params', {}) %}
                        <div class="lang-toggle mt-4">
                            <a href="{{ path(home_route) }}" class="active">LU</a>
                            <a href="{{ path(switch_route, switch_params) }}">EN</a>
                        </div>
                    {% else %}
                        {% set route_map = {
                            'app_home_en': 'app_home',
                            'app_news_en': 'app_news',
                            'app_news_show_en': 'app_news_show',
                            'app_contact_en': 'app_contact'
                        } %}
                        {% set switch_route = route_map[app.request.attributes.get('_route')] ?? 'app_home' %}
                        {% set switch_params = app.request.attributes.get('_route_params', {}) %}
                        <div class="lang-toggle mt-4">
                            <a href="{{ path(switch_route, switch_params) }}">LU</a>
                            <a href="{{ path(home_route) }}" class="active">EN</a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </header>

        {# --- Main Content --- #}
        <main class="flex-grow">
            {% block body %}{% endblock %}
        </main>

        {# --- Footer --- #}
        <footer class="bg-cream">
            <div class="footer-divider"></div>
            <div class="max-w-6xl mx-auto px-5 sm:px-8 lg:px-10 py-10">
                <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
                    <p class="text-[0.8rem] tracking-wide text-text-muted">
                        <span class="text-blue font-semibold">Mika (Michael) Ferreira</span>
                        <span class="mx-2 text-gold">&middot;</span>
                        <span class="font-semibold text-blue">DP Kayl-Téiteng</span>
                    </p>
                    <div class="flex items-center gap-3">
                        <a href="mailto:email@michael-ferreira.com" class="text-text-soft hover:text-blue transition-colors" aria-label="E-Mail">
                            <svg class="w-[1.1rem] h-[1.1rem]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
                        </a>
                        <a href="https://www.facebook.com/unique.mf.95/" target="_blank" rel="noopener noreferrer" class="text-text-soft hover:text-[#1877F2] transition-colors" aria-label="Facebook">
                            <svg class="w-[1.1rem] h-[1.1rem]" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                        </a>
                        <a href="https://www.instagram.com/michaelferreira.lu/" target="_blank" rel="noopener noreferrer" class="text-text-soft hover:text-[#E4405F] transition-colors" aria-label="Instagram">
                            <svg class="w-[1.1rem] h-[1.1rem]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                        </a>
                        <a href="https://www.linkedin.com/in/michael-ferreira-2b53449a/" target="_blank" rel="noopener noreferrer" class="text-text-soft hover:text-[#0A66C2] transition-colors" aria-label="LinkedIn">
                            <svg class="w-[1.1rem] h-[1.1rem]" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                        </a>
                    </div>
                </div>
            </div>
        </footer>

    </body>
</html>
