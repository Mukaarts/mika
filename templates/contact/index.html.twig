{% extends 'base.html.twig' %}

{% block title %}{{ 'contact.title'|trans }} — Mika Ferreira{% endblock %}

{% block body %}

    {# === Hero banner === #}
    <section class="relative pt-36 pb-20 hero-gradient overflow-hidden">
        <div class="absolute inset-0 hero-pattern"></div>
        <div class="relative z-10 max-w-4xl mx-auto px-5 sm:px-8 lg:px-10 text-center">
            <p class="section-label justify-center mb-6 text-white/40 before:bg-gold">{{ 'nav.contact'|trans }}</p>
            <h1 class="font-display text-[2.5rem] sm:text-[3.25rem] font-bold text-white mb-5 leading-tight">
                {{ 'home.contact.headline'|trans }}
            </h1>
            <p class="text-white/50 text-[1.05rem] leading-relaxed max-w-lg mx-auto">
                {{ 'home.contact.description'|trans }}
            </p>
        </div>
    </section>

    {# === Contact info === #}
    <section class="py-20 bg-cream">
        <div class="max-w-4xl mx-auto px-5 sm:px-8 lg:px-10">

            {# Cards Grid #}
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-16 -mt-28 relative z-20">
                {# Email #}
                <a href="mailto:email@michael-ferreira.com" class="contact-card group p-7 rounded-2xl bg-white border border-cream-dark/50 text-center">
                    <div class="w-14 h-14 rounded-2xl bg-blue-light flex items-center justify-center mx-auto mb-5 group-hover:bg-blue group-hover:scale-105 transition-all duration-300">
                        <svg class="w-6 h-6 text-blue group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
                        </svg>
                    </div>
                    <span class="block text-[0.6rem] font-bold uppercase tracking-[0.18em] text-text-soft mb-2">E-Mail</span>
                    <span class="text-navy text-[0.875rem] font-semibold group-hover:text-blue transition-colors">email@michael-ferreira.com</span>
                </a>

                {# Location #}
                <div class="contact-card p-7 rounded-2xl bg-white border border-cream-dark/50 text-center">
                    <div class="w-14 h-14 rounded-2xl bg-blue-light flex items-center justify-center mx-auto mb-5">
                        <svg class="w-6 h-6 text-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
                        </svg>
                    </div>
                    <span class="block text-[0.6rem] font-bold uppercase tracking-[0.18em] text-text-soft mb-2">{{ 'home.contact.location'|trans }}</span>
                    <span class="text-navy text-[0.875rem] font-semibold">Luxembourg</span>
                </div>

                {# Party #}
                <div class="contact-card p-7 rounded-2xl bg-white border border-cream-dark/50 text-center">
                    <div class="w-14 h-14 rounded-2xl bg-gold-light flex items-center justify-center mx-auto mb-5">
                        <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/>
                        </svg>
                    </div>
                    <span class="block text-[0.6rem] font-bold uppercase tracking-[0.18em] text-text-soft mb-2">Partei</span>
                    <span class="text-navy text-[0.875rem] font-semibold">DP Kayl-Téiteng</span>
                </div>
            </div>

            {# Social section #}
            <div class="text-center">
                <p class="text-[0.65rem] font-bold uppercase tracking-[0.18em] text-text-soft mb-6">Social Media</p>
                <div class="flex items-center justify-center gap-5">
                    <a href="https://www.facebook.com/unique.mf.95/" target="_blank" rel="noopener noreferrer"
                       class="social-icon group w-14 h-14 rounded-2xl bg-white border border-cream-dark/50 flex items-center justify-center" aria-label="Facebook">
                        <svg class="w-6 h-6 text-text-muted group-hover:text-[#1877F2] transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                        </svg>
                    </a>
                    <a href="https://www.instagram.com/michaelferreira.lu/" target="_blank" rel="noopener noreferrer"
                       class="social-icon group w-14 h-14 rounded-2xl bg-white border border-cream-dark/50 flex items-center justify-center" aria-label="Instagram">
                        <svg class="w-6 h-6 text-text-muted group-hover:text-[#E4405F] transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                        </svg>
                    </a>
                    <a href="https://www.linkedin.com/in/michael-ferreira-2b53449a/" target="_blank" rel="noopener noreferrer"
                       class="social-icon group w-14 h-14 rounded-2xl bg-white border border-cream-dark/50 flex items-center justify-center" aria-label="LinkedIn">
                        <svg class="w-6 h-6 text-text-muted group-hover:text-[#0A66C2] transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </section>

{% endblock %}
